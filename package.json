{
  "name": "cloud-task-manager-api",
  "version": "1.0.0",
  "description": "RESTful Cloud Task Manager API built with Node.js, Express, and PostgreSQL",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "setupFiles": [
      "./tests/setup.js"
    ]
  },
  "dependencies": {
    "bcrypt": "5.1.1",
    "dotenv": "16.3.1",
    "express": "4.18.2",
    "joi": "17.11.0",
    "jsonwebtoken": "9.0.2",
    "pg": "8.11.3"
  },
  "devDependencies": {
    "fast-check": "3.14.0",
    "jest": "29.7.0",
    "nodemon": "3.0.2",
    "supertest": "6.3.4"
  }
}
